# ClaudeRemote Configuration

# Telegram bot token from @BotFather
TELEGRAM_BOT_TOKEN=123456789:ABCdefGHIjklMNOpqrsTUVwxyzABCDEfgh

# Comma-separated list of Telegram numeric user IDs allowed to use this bot
# Get your ID from @userinfobot
ALLOWLIST=123456789,987654321

# Absolute path to the git repository where Claude Code will work
# This directory must exist and be a git repository
WORKSPACE_PATH=/Users/you/path/to/your/project

# Path to the SQLite database file for task history
# Default: ./data/claude-remote.db (relative to current working directory)
# SQLITE_PATH=./data/claude-remote.db

# Logging level: trace, debug, info, warn, error
# Default: info
# LOG_LEVEL=info

# How often to update the progress message in Telegram (milliseconds)
# Minimum 1500 to respect Telegram's rate limits
# Default: 3000
# PROGRESS_EDIT_INTERVAL_MS=3000

# How long to wait before timing out a task (milliseconds)
# Default: 1800000 (30 minutes)
# TASK_TIMEOUT_MS=1800000

# Port for the hook HTTP server (for Claude Code Stop hook callbacks)
# Default: 4711
# HOOK_HTTP_PORT=4711

# Whether to skip Claude Code permission prompts
# Default: true (not recommended for shared/untrusted code)
# CC_SKIP_PERMISSIONS=true
