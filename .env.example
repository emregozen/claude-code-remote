# ClaudeRemote — environment configuration
# Copy this file to `.env` and fill in the required values.
# See SPEC.md §4.1 for the full reference.

# ---- Required ----

# Bot token from @BotFather. Format: <digits>:<alphanum-and-dashes>
TELEGRAM_BOT_TOKEN=

# Comma-separated Telegram numeric user IDs permitted to use this bot.
# Find your ID by messaging @userinfobot on Telegram.
# At least one ID required. Non-listed senders are silently rejected.
ALLOWLIST=

# Anthropic API key for Claude Code SDK. Starts with `sk-ant-`.
ANTHROPIC_API_KEY=

# Absolute host path to your project directory. Will be mounted read-write
# into the cc-runner container at /workspace. Must be an existing git repo.
WORKSPACE_PATH=

# ---- Optional (sensible defaults shown) ----

# REDIS_URL=redis://redis:6379
# SQLITE_PATH=/data/claude-remote.db
# LOG_LEVEL=info
# PROGRESS_EDIT_INTERVAL_MS=3000
# TASK_TIMEOUT_MS=1800000

# MVP default is `true` — CC runs with --dangerously-skip-permissions.
# See SPEC.md §10.3.3 for security implications.
# CC_SKIP_PERMISSIONS=true
