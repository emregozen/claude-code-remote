{
  "name": "claude-remote",
  "version": "0.1.0-mvp",
  "description": "Mobile-first remote control for Claude Code via Telegram",
  "private": true,
  "type": "module",
  "workspaces": ["packages/shared", "packages/bot", "packages/cc-runner"],
  "scripts": {
    "typecheck": "npm run --workspaces typecheck",
    "lint": "biome check .",
    "format": "biome format --write .",
    "build": "npm run --workspaces build",
    "dev": "npm run --workspaces dev"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.8.0",
    "@types/better-sqlite3": "^7.6.13",
    "tsx": "^4.15.0",
    "typescript": "^5.4.0",
    "vitest": "^2.0.0"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
