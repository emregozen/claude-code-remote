{
  "name": "claude-remote",
  "version": "0.1.0-mvp",
  "description": "Mobile-first remote control for Claude Code via Telegram",
  "private": true,
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "tsx src/index.ts",
    "typecheck": "tsc --noEmit",
    "lint": "biome check src",
    "format": "biome format --write src",
    "test": "vitest run"
  },
  "dependencies": {
    "@anthropic-ai/claude-code": "^2.1.119",
    "better-sqlite3": "^11.0.0",
    "dotenv": "^16.4.0",
    "execa": "^9.0.0",
    "fastify": "^4.28.0",
    "grammy": "^1.24.0",
    "pino": "^9.0.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.8.0",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^20.0.0",
    "tsx": "^4.15.0",
    "typescript": "^5.4.0",
    "vitest": "^2.0.0"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
